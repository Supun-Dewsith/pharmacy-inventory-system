                  <ButtonBar nodeOrientation="RIGHT_TO_LEFT" prefHeight="46.0" prefWidth="821.0">
                    <buttons>
                        <JFXButton style="-fx-background-color: #CFCFCF;" text="Print Receipt">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
