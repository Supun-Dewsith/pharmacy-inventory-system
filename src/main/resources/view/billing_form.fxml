               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <ButtonBar prefHeight="40.0" prefWidth="200.0" GridPane.columnIndex="1">
                     <buttons>
                        <JFXButton style="-fx-background-color: #CFCFCF;" text="Confirm">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font></JFXButton>
                     </buttons>
                     <GridPane.margin>
                        <Insets right="10.0" />
                     </GridPane.margin>
                  </ButtonBar>
               </children>
            </GridPane>
            <GridPane GridPane.rowIndex="1">
