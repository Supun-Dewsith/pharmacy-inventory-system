<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox prefHeight="703.0" prefWidth="370.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.suplier.EditSupplierFormController">
   <children>
      <Label text="Edit Supplier">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets left="10.0" top="20.0" />
         </VBox.margin>
      </Label>
      <JFXTextField fx:id="txtSupplierName" promptText="Supplier Name">
         <VBox.margin>
            <Insets left="10.0" right="20.0" top="10.0" />
         </VBox.margin>
      </JFXTextField>
      <JFXTextField fx:id="txtContactPerson" promptText="Contact person">
         <VBox.margin>
            <Insets left="10.0" right="20.0" top="10.0" />
         </VBox.margin>
      </JFXTextField>
      <JFXTextField fx:id="txtPhone" promptText="Phone">
         <VBox.margin>
            <Insets left="10.0" right="20.0" top="10.0" />
         </VBox.margin>
      </JFXTextField>
      <JFXTextField fx:id="txtEmail" promptText="Batch Nimber" text="Email">
         <VBox.margin>
            <Insets left="10.0" right="20.0" top="10.0" />
         </VBox.margin>
      </JFXTextField>
      <JFXTextField fx:id="txtStatus" promptText="Categury" text="Status">
         <VBox.margin>
            <Insets left="10.0" right="20.0" top="10.0" />
         </VBox.margin>
      </JFXTextField>
      <VBox alignment="BOTTOM_CENTER" prefHeight="483.0" prefWidth="370.0">
         <children>
            <JFXButton onAction="#btnAddSuplierOnAction" prefHeight="25.0" prefWidth="110.0" text="Confirm" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets bottom="5.0" left="20.0" right="20.0" top="10.0" />
               </VBox.margin>
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </JFXButton>
         </children>
      </VBox>
   </children>
</VBox>
